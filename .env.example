# .env.example — Solution Acceleration Engine environment variables.
#
# Copy this file to .env and fill in your values before running docker-compose:
#
#   cp .env.example .env
#   # Edit .env — add your API keys
#   docker-compose up --build
#
# IMPORTANT: Never commit a populated .env file to version control.
# This example file is safe to commit — it contains no real credentials.

# ── LLM Provider API Keys ──────────────────────────────────────────────────────
# At least one provider key is required to run LLM-backed reviews.
# Leave keys empty to start the container in "admin config only" mode —
# you can enter keys via the Admin page in the UI after startup.

# Groq — fast inference, supports Llama and Mixtral models.
# Get a key at: https://console.groq.com
GROQ_API_KEY=

# OpenRouter — unified gateway to 100+ models (GPT-4o, Claude, Mistral, etc.).
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini — Google's multimodal LLM family.
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Ollama (local / self-hosted LLM) ──────────────────────────────────────────
# Set this if Ollama runs on a different host or port than the default.
# Default: http://localhost:11434
# Example for a remote Ollama server: http://192.168.1.50:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── Application settings ───────────────────────────────────────────────────────
# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: WARNING (quiet in production)
CONTEXTA_LOG_LEVEL=WARNING

# SQLite database path inside the container.
# Mapped to the ./data host volume — do not change unless you also update
# the docker-compose.yml volumes section.
CONTEXTA_DB_PATH=/app/data/contexta.db

# Export output path inside the container.
# Mapped to the ./exports host volume.
CONTEXTA_EXPORT_PATH=/app/exports
