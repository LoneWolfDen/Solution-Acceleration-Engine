# .env.example — Environment variables for Solution Acceleration Engine
#
# Copy this file to .env and fill in your values before starting the app.
#   cp .env.example .env
#
# Lines starting with # are comments and are ignored.
# Remove the leading # to activate a variable.

# ── LLM Provider Configuration ────────────────────────────────────────────────
# Unified LLM configuration - use either CONTEXTA_LLM_BACKEND (legacy) or
# the new platform-agnostic variables below.

# LLM Provider (e.g. "nvidia", "groq", "openai")
# LLM_PROVIDER=nvidia

# LLM Model Name (e.g. "meta/llama-3.1-70b-instruct", "llama3-70b-8192")
# LLM_MODEL_NAME=meta/llama-3.1-70b-instruct

# LLM API Key (automatically mapped based on provider)
# LLM_API_KEY=

# LLM Base URL (crucial for NVIDIA NIM)
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# LLM Timeout in seconds (default 120)
# LLM_TIMEOUT=120

# ── Legacy LLM Provider API Keys ───────────────────────────────────────────────
# At least ONE provider key is required to run reviews and proposals.
# Leave the others blank (or remove them) if you don't have keys for them.

GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── Headroom AI Proxy ─────────────────────────────────────────────────────────
# Routes ALL LLM traffic through the local Headroom proxy for semantic caching.
# This saves 50–90 % of tokens on repeated or similar prompts.
#
# Start the proxy before the app: `headroom proxy --port 8787`
#
# Both variables must point at Headroom — do NOT change the paths (/v1 and /).
# "localhost" works for native dev (Method B) and for Docker when the proxy
# runs on the HOST machine (Docker resolves host.docker.internal → host loopback).

OPENAI_BASE_URL=http://localhost:8787/v1
ANTHROPIC_BASE_URL=http://localhost:8787

# ── Ollama (optional — local open-source models) ──────────────────────────────
# Only needed if you run a local Ollama instance.
#
# Native / bare-metal:
OLLAMA_BASE_URL=http://localhost:11434
#
# Docker — comment the line above and uncomment this one:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Database path ─────────────────────────────────────────────────────────────
# Default (local dev): contexta.db in the project root — matches rxconfig.py.
# Override for Docker or custom mount points.
#
# Local dev (default — no override needed):
# CONTEXTA_DB_PATH=contexta.db
#
# Docker / production:
# CONTEXTA_DB_PATH=/app/data/contexta.db

# ── Application settings ──────────────────────────────────────────────────────
# CONTEXTA_LOG_LEVEL=INFO

# ── Reflex API URL ────────────────────────────────────────────────────────────
# Tells the compiled frontend where to find the Reflex WebSocket backend.
# Only needed if the auto-detection in rxconfig.py doesn't pick up your URL.
#
# REFLEX_API_URL=http://localhost:8000
