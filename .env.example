# .env.example — Environment variables for Solution Acceleration Engine
#
# Copy this file to .env and fill in your provider keys.
# docker-compose.yml reads from .env automatically.
#
# No keys are baked into the Docker image — all injected at runtime.

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# At least one provider must be configured to run reviews/proposals.
# Leave blank (or remove) any providers you don't use.

GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# URL for a locally-running Ollama instance.
# Default: http://host.docker.internal:11434 (Docker host access)
# Set to http://localhost:11434 if running outside Docker.

OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Application Settings ──────────────────────────────────────────────────────
# These have sensible defaults and rarely need changing.

# Path to SQLite database file (inside the container).
# The ./data directory is bind-mounted, so the DB persists across restarts.
# CONTEXTA_DB_PATH=/app/data/contexta.db

# Log level: DEBUG, INFO, WARNING, ERROR
# CONTEXTA_LOG_LEVEL=WARNING
