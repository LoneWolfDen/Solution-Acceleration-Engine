{
  // Codespaces devcontainer for Solution Acceleration Engine.
  // Opens a Python 3.11 environment with Node 20 pre-installed.
  // All Python dependencies are installed via `pip install -e ".[dev]"` on
  // container creation; the API starts automatically so the first thing you
  // need to run after `git pull` is `python -m reflex run`.

  "name": "Solution Acceleration Engine",

  // Use the Microsoft Python 3.11 devcontainer image — pre-ships git, curl,
  // sudo, and common utilities without requiring a custom Dockerfile build.
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",

  "features": {
    // Node 20 LTS — required by Reflex's bun/Next.js build toolchain.
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  // Install all Python and dev dependencies (editable install so source
  // changes are reflected immediately without reinstalling).
  "postCreateCommand": "pip install --upgrade pip && pip install -e '.[dev]' && python -m reflex init",

  // Start the FastAPI API automatically on container start so `python -m
  // reflex run` is the only manual step needed.
  "postStartCommand": "bash scripts/dev-start.sh",

  // Forward all three service ports to GitHub Codespace proxy URLs.
  "forwardPorts": [3000, 8000, 8001],
  "portsAttributes": {
    "3000": {
      "label": "Reflex Frontend",
      "onAutoForward": "openBrowser"
    },
    "8000": {
      "label": "FastAPI REST API",
      "onAutoForward": "silent"
    },
    "8001": {
      "label": "Reflex State-Sync",
      "onAutoForward": "silent"
    }
  },

  // Remote environment — Reflex derives its api_url from CODESPACE_NAME when
  // present; this is injected automatically by Codespaces.
  "remoteEnv": {
    "CONTEXTA_API_URL": "http://localhost:8000"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  }
}
